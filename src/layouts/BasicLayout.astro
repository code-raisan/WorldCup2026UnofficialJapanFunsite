---
import Root from "@/layouts/Root.astro";
import HeaderNav from "@/components/HeaderNav.astro";
import FooterNav from "@/components/FooterNav.astro";

const { title, heading, details } = Astro.props;
---

<Root title={title}>
  <HeaderNav/>
  <div class="mt-22.5 max-w-5xl px-5 mx-auto space-y-16">
    <div class="flex flex-wrap items-baseline border-b-4 pb-3 border-[#333333] space-x-3">
      <h1 class="text-5xl font-extrabold">{heading}</h1>
      <p class="text-2xl font-bold">{details}</p>
    </div>
  </div>
  <main class="max-w-5xl mt-10 px-5 mx-auto space-y-16 min-h-[80svh]">
    <slot/>
  </main>
  <FooterNav/>
</Root>
