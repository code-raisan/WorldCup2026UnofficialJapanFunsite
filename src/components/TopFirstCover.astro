---
import SiteLogoWhite from "@/assets/sitelogo-white.svg";
---
<div class="h-svh w-full z-0">
  <div class="h-full w-full bg-black/40 text-white relative">
    <div class="absolute bottom-0 left-0 m-10">
      <div class="w-full">
        <SiteLogoWhite class:list={"w-full"}/>
      </div>
      <p>FIFA ワールドカップ 2026 非公式ファンサイト</p>
    </div>
  </div>
  <div class="yt-embed-wrapper">
    <iframe
      id="yt-embed"
      width="560" height="315"
      src="ttps://www.youtube-nocookie.com/embed/eHGpAbpVX3U?autoplay=1&mute=1&loop=1&controls=0&showinfo=0&modestbranding=1&rel=0&iv_load_policy=3&disablekb=1"
      title="YouTube video player"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      referrerpolicy="strict-origin-when-cross-origin">
    </iframe>
  </div>
</div>

<style>
  .rubik-glitch {
    font-family: "Rubik Glitch", system-ui;
  }

  .yt-embed-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: -1;
    pointer-events: none;
  }

  #yt-embed {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);

    width: 177.77777778svh;
    height: 100svh;
    min-width: 100svw;
    min-height: 56.25svw;
  }
</style>
